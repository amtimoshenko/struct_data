// 25. Реалзовать алгоритм быстрого возведения в степень: a^n = (a^(n/2))² при чётном n; a^n = a·a^(n−1) при нечётном n.
//Определить временную сложность O(log n). Сравнить число умножений с наивным алгоритмом O(n) при n = 16.
#include <iostream>
#include <cmath>
using namespace std;

// Функция быстрого возведения в степень
long long fast_pow(long long a, int n, int &count) {
    // Если степень 0, результат всегда 1
    if (n == 0) {
        return 1;
    }
    // Если степень 1, результат — само число
    if (n == 1) {
        return a;
    }

    // Если n чётное: a^n = (a^(n/2))²
    if (n % 2 == 0) {
        long long temp = fast_pow(a, n / 2, count);  
        count++;  
        return temp * temp;
    } else {
        // Если n нечётное: a^n = a * a^(n-1)
        count++;  
        return a * fast_pow(a, n - 1, count);
    }
}

// Простая функция — просто умножаем a на себя n раз
long long simple_pow(long long a, int n, int &count) {
    long long res = 1; 

    for (int i = 0; i < n; i++) {
        res = res * a; 
        count++;       
    }

    return res;
}

long long fast_power_log(long long a, int n) {
    long long result=1;
    long long base=a;
    int step=0;
    
    while(n>0){
        step++;
        double current_log=log2(n);
        cout << "Шаг:" << step << " n=" << n << " log_2(n)=" << current_log << endl;
    
    if(n%2==1){
        result*=base;
        n--;
    }else{
        base*=base;
        n/=2;
    }
    }
    return result;
}
int main() {
    long long a;     
    int n = 16;    
    int fast_count = 0;    
    int simple_count = 0; 
    cout << "Считаем a^16 двумя способами.\n";
    cout << "Введи число a: ";
    cin >> a;

    long long fast_result = fast_pow(a, n, fast_count);

    long long simple_result = simple_pow(a, n, simple_count);

    cout << "\n--- РЕЗУЛЬТАТЫ ---\n";
    cout << "Число: " << a << ", степень: " << n << "\n";
    cout << "Быстрый способ: " << fast_result << " (умножений: " << fast_count << ")\n";
    long long res=fast_power_log(a,n);
    cout << "Простой способ: " << simple_result << " (умножений: " << simple_count << ")\n";

    cout << "\nСРАВНЕНИЕ:\n";
    cout << "Быстрый способ сделал на " << (simple_count - fast_count)
         << " умножений меньше!\n";
    cout << "Это в " << (double)simple_count / fast_count
         << " раз быстрее!\n";
    

    return 0;
}
